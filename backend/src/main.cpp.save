#include <fstream>
#include <iostream>
#include <string>
#include <sstream>
#include <crow.h>
#include "problems/assignment/instances/fmcg_productos_tiendas.cpp"

// Lee un archivo completo
std::string read_file(const std::string& path) {
    std::ifstream file(path, std::ios::binary);
    if (!file) return "";
    std::stringstream buffer;
    buffer << file.rdbuf();
    return buffer.str();
}

// Función auxiliar para ends_with
bool ends_with(const std::string& str, const std::string& suffix) {
    if (str.length() < suffix.length()) return false;
    return str.compare(str.length() - suffix.length(), suffix.length(), suffix) == 0;
}

int main() {
    crow::SimpleApp app;

    // Ruta principal: sirve el index.html
    CROW_ROUTE(app, "/")([]() {
        auto html = read_file("frontend/index.html");
        if (html.empty()) {
            return crow::response(500, "Error loading frontend");
        }
        crow::response res(html);
        res.set_header("Content-Type", "text/html");
        return res;
    });

    // Ruta para el CSS
    CROW_ROUTE(app, "/style.css")([]() {
        auto css = read_file("frontend/style.css");
        if (css.empty()) {
            return crow::response(404, "CSS not found");
        }
        crow::response res(css);
        res.set_header("Content-Type", "text/css");
        return res;
    });

    // Ruta para el JavaScript
    CROW_ROUTE(app, "/script.js")([]() {
        auto js = read_file("frontend/script.js");
        if (js.empty()) {
            return crow::response(404, "JS not found");
        }
        crow::response res(js);
        res.set_header("Content-Type", "application/javascript");
        return res;
    });

    // Ruta para la optimización (POST)
    CROW_ROUTE(app, "/optimize").methods(crow::HTTPMethod::Post)([](const crow::request& req) {
        // Por ahora devolvemos un JSON de prueba
        crow::json::wvalue result;
        

// Ruta para servir assets (logo, imágenes)
CROW_ROUTE(app, "/assets/<string>")([](const std::string& filename) {
    std::string path = "frontend/assets/" + filename;
    std::cout << "Intentando servir: " << path << std::endl;  // Para debug
    
    auto content = read_file(path);
    if (content.empty()) {
        std::cerr << "No se encontró: " << path << std::endl;
        return crow::response(404);
    }
    
    crow::response res(content);
    
    if (ends_with(filename, ".css")) res.set_header("Content-Type", "text/css");
else if (ends_with(filename, ".js")) res.set_header("Content-Type", "application/javascript");
else if (ends_with(filename, ".png")) {
    std::cout << "Sirviendo PNG: " << filename << ", tamaño: " << content.size() << " bytes" << std::endl;
    res.set_header("Content-Type", "image/png");
}
else if (ends_with(filename, ".svg")) res.set_header("Content-Type", "image/svg+xml");
else if (ends_with(filename, ".jpg") || ends_with(filename, ".jpeg")) res.set_header("Content-Type", "image/jpeg");
else if (ends_with(filename, ".ico")) res.set_header("Content-Type", "image/x-icon");
    
    return res;
});
    app.port(8080).multithreaded().run();
}
