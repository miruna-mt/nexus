<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexus - Optimización Multi-Industria</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
<div style="text-align: center; margin: 5px auto 0 auto;">
    <img src="/assets/logo.png" alt="Nexus Logo" style="max-width: 180px; height: auto; display: inline-block;">
</div>
    <div class="container">
        <!--<h1>Nexus</h1>-->
        <p class="subtitle">Motor de optimización multi-industria</p>
        
        <div class="selector">
            <label for="problemType">Tipo de problema:</label>
            <select id="problemType">
                <option value="assignment">Asignación (Assignment)</option>
                <option value="routing">Ruteo (Routing)</option>
                <option value="inventory">Inventario (Inventory)</option>
                <option value="portfolio">Carteras (Portfolio)</option>
                <option value="location">Localización (Location)</option>
                <option value="stochastic">Incertidumbre (Stochastic)</option>
                <option value="scheduling">Secuenciación (Scheduling)</option>
            </select>
        </div>

        <div class="selector">
            <label for="instance">Instancia:</label>
            <select id="instance">
                <option value="fmcg_productos_tiendas">FMCG - Productos a Tiendas</option>
            </select>
        </div>

        <button id="optimizeBtn">Optimizar</button>

        <div id="results" class="results">
            <h3>Resultados:</h3>
            <pre id="output">Esperando entrada...</pre>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
